#!/usr/bin/env bash
# Ship both services: rust-spades backend, then spades-ts frontend (Cloudflare Pages).
# Bails on the first failure; the frontend isn't touched if the backend deploy fails.
#
# Optional:
#   SPADES_TS_DIR     path to spades-ts checkout (default: ../spades-ts relative to this repo)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SPADES_TS_DIR="${SPADES_TS_DIR:-$(cd "$REPO_ROOT/.." && pwd)/spades-ts}"

if [ ! -x "$SPADES_TS_DIR/bin/deploy" ]; then
    echo "Error: $SPADES_TS_DIR/bin/deploy missing or not executable" >&2
    echo "       set SPADES_TS_DIR or create bin/deploy in spades-ts" >&2
    exit 1
fi

echo "==> [1/2] backend"
"$SCRIPT_DIR/deploy"
BACKEND_SHA="$(git -C "$REPO_ROOT" rev-parse --short=12 HEAD)"

echo "==> [2/2] frontend"
"$SPADES_TS_DIR/bin/deploy"
FRONTEND_SHA="$(git -C "$SPADES_TS_DIR" rev-parse --short=12 HEAD)"

echo
echo "==> All done."
echo "    backend  $BACKEND_SHA  -> $DEPLOY_HOST"
echo "    frontend $FRONTEND_SHA -> Cloudflare Pages"
