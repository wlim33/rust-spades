{
  "name": "spades-ts",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run --project=unit",
    "test:component": "vitest run --project=component",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit && pnpm test:component",
    "openapi:fetch": "bash openapi/fetch.sh",
    "openapi:generate": "bash openapi/generate.sh",
    "openapi:check": "bash openapi/generate.sh && git diff --exit-code src/api/schema.d.ts"
  },
  "dependencies": {
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@preact/signals-core": "^1.8.0",
    "lit-html": "^3.2.0",
    "navaid": "^1.2.0",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.9.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.12.0"
}
