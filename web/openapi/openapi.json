{
  "openapi": "3.0.3",
  "info": {
    "title": "Spades Game Server",
    "description": "4-player Spades card game server with matchmaking, challenges, and real-time updates.",
    "version": "3.0.0"
  },
  "paths": {
    "/games/{game_id}": {
      "get": {
        "operationId": "handlers_games_get_game_state",
        "parameters": [
          {
            "name": "game_id",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "path",
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "game_id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "short_id": {
                      "type": "string"
                    },
                    "state": {
                      "oneOf": [
                        {
                          "type": "string",
                          "enum": ["NotStarted", "Completed", "Aborted"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "Bidding": {
                              "type": "integer"
                            }
                          },
                          "required": ["Bidding"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "Trick": {
                              "type": "integer"
                            }
                          },
                          "required": ["Trick"]
                        }
                      ]
                    },
                    "team_a_score": {
                      "nullable": true,
                      "type": "integer"
                    },
                    "team_b_score": {
                      "nullable": true,
                      "type": "integer"
                    },
                    "team_a_bags": {
                      "nullable": true,
                      "type": "integer"
                    },
                    "team_b_bags": {
                      "nullable": true,
                      "type": "integer"
                    },
                    "current_player_id": {
                      "nullable": true,
                      "type": "string",
                      "format": "uuid"
                    },
                    "player_names": {
                      "type": "array",
                      "items": {
                        "description": "A player's name entry",
                        "type": "object",
                        "properties": {
                          "player_id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "name": {
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "required": ["player_id"]
                      }
                    },
                    "timer_config": {
                      "nullable": true,
                      "description": "Fischer increment timer configuration (X+Y: X minutes initial, Y seconds increment per move).",
                      "type": "object",
                      "properties": {
                        "initial_time_secs": {
                          "type": "integer"
                        },
                        "increment_secs": {
                          "type": "integer"
                        }
                      },
                      "required": ["initial_time_secs", "increment_secs"]
                    },
                    "player_clocks_ms": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "active_player_clock_ms": {
                      "nullable": true,
                      "type": "integer"
                    },
                    "table_cards": {
                      "type": "array",
                      "items": {
                        "description": "Intuitive card struct. Ordered by suit (Club < Diamond < Heart < Spade),\nthen rank ascending \u2014 the derived lexicographic order over the fields.",
                        "type": "object",
                        "properties": {
                          "suit": {
                            "$ref": "#/components/schemas/Suit"
                          },
                          "rank": {
                            "$ref": "#/components/schemas/Rank"
                          }
                        },
                        "required": ["suit", "rank"]
                      }
                    },
                    "player_bets": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "player_tricks_won": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "last_trick_winner_id": {
                      "nullable": true,
                      "type": "string",
                      "format": "uuid"
                    },
                    "last_completed_trick": {
                      "type": "array",
                      "items": {
                        "description": "Intuitive card struct. Ordered by suit (Club < Diamond < Heart < Spade),\nthen rank ascending \u2014 the derived lexicographic order over the fields.",
                        "type": "object",
                        "properties": {
                          "suit": {
                            "$ref": "#/components/schemas/Suit"
                          },
                          "rank": {
                            "$ref": "#/components/schemas/Rank"
                          }
                        },
                        "required": ["suit", "rank"]
                      }
                    }
                  },
                  "required": ["game_id", "short_id", "state", "player_names"]
                }
              }
            }
          }
        }
      }
    },
    "/games/{game_id}/replay.json": {
      "get": {
        "description": "Return a JSON replay of a terminal game. Refused (403) for in-progress\ngames \u2014 the model would expose hidden hands. Resolves `viewer_seat` from\nthe auth `Identity` so clients can orient the replay to the viewer.\nThe response also includes a typed `termination` field (`\"completed\"` or\n`\"aborted\"`) to distinguish normal finishes from timed-out games.\n\n`identity` is `OptionalIdentity` (a newtype over `Option<Identity>`) so\nthat a request with a present-but-unrecognized Bearer token (e.g. a\nrevoked API token) still receives the replay with `viewer_seat: null`\nrather than a 401. No-credential and cookie-session paths still resolve\nto `Some(Anonymous)` or `Some(Registered)` as before; only the\ninvalid-Bearer case changes from 401 \u2192 200-with-null-seat.",
        "operationId": "handlers_games_get_replay_json",
        "parameters": [
          {
            "name": "game_id",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "path",
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameReplayResponse"
                }
              }
            }
          }
        }
      }
    },
