  "components": {
    "schemas": {
      "Card": {
        "description": "Intuitive card struct. Ordered by suit (Club < Diamond < Heart < Spade),\nthen rank ascending \u2014 the derived lexicographic order over the fields.",
        "type": "object",
        "properties": {
          "suit": {
            "$ref": "#/components/schemas/Suit"
          },
          "rank": {
            "$ref": "#/components/schemas/Rank"
          }
        },
        "required": ["suit", "rank"]
      },
      "ChallengeConfig": {
        "description": "Configuration for creating a challenge.",
        "type": "object",
        "properties": {
          "max_points": {
            "type": "integer"
          },
          "timer_config": {
            "$ref": "#/components/schemas/TimerConfig"
          },
          "creator_seat": {
            "$ref": "#/components/schemas/Seat"
          },
          "creator_name": {
            "nullable": true,
            "type": "string"
          },
          "expiry_secs": {
            "type": "integer"
          }
        },
        "required": ["max_points", "expiry_secs"]
      },
      "ChallengeStatusKind": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "game_id": {
                "type": "string",
                "format": "uuid"
              },
              "status": {
                "type": "string",
                "enum": ["started"]
              }
            },
            "required": ["game_id", "status"]
          },
          {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["open", "cancelled", "expired"]
              }
            },
            "required": ["status"]
          }
        ]
      },
      "ChatRequest": {
        "type": "object",
        "properties": {
          "player_id": {
            "type": "string",
            "format": "uuid"
          },
          "content": {
            "type": "string"
          }
        },
        "required": ["player_id", "content"]
      },
      "CreateGameRequest": {
        "type": "object",
        "properties": {
          "max_points": {
            "type": "integer"
          },
          "timer_config": {
            "$ref": "#/components/schemas/TimerConfig"
          },
          "num_humans": {
            "nullable": true,
            "type": "integer"
          }
        },
        "required": ["max_points"]
      },
      "DealtHand": {
        "description": "One hand in a `Deal` event: the target seat/pile and the cards dealt to it.",
        "type": "object",
        "properties": {
          "target": {
            "type": "string"
          },
          "cards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Card"
            }
          }
        },
        "required": ["target", "cards"]
      },
      "Deck": {
        "type": "object",
        "properties": {
          "suits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ranks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["suits", "ranks"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": ["error"]
      },
      "Event": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "hands": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DealtHand"
                }
              },
              "type": {
                "type": "string",
                "enum": ["deal"]
              }
            },
            "required": ["hands", "type"]
          },
          {
            "type": "object",
            "properties": {
              "start": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "type": {
                "type": "string",
                "enum": ["call"]
              }
            },
            "required": ["start", "values", "type"]
          },
          {
            "type": "object",
