#!/usr/bin/env bash
# Pre-push gate: refuse to push if clippy, tests, or coverage check fail.
# Enable with:  git config core.hooksPath hooks
# Skip once with:  git push --no-verify
set -euo pipefail

if [ "${SKIP_HOOKS:-0}" = "1" ]; then
    echo "SKIP_HOOKS=1 — skipping pre-push checks." >&2
    exit 0
fi

export PATH="$HOME/.cargo/bin:$PATH"

echo "==> cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "==> cargo test --workspace"
cargo test --workspace

echo "==> hooks/coverage-check.sh"
"$(dirname "$0")/coverage-check.sh"

echo "==> All checks passed."
